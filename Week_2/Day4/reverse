class Solution {
public:
    string reverseWords(string s) {
        int p=0;
        int n=s.size();
        for(int i=0;i<n;i++){
            if(s[i]==' '){
                reverse(s.begin()+p,s.begin()+i);
                p=i+1;
            }
        }
        reverse(s.begin()+p,s.end());
        return s;
    }
};
